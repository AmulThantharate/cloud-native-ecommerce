# ──────────────────────────────────────────────────────────
# 📐 NexStore — .gitattributes
# ──────────────────────────────────────────────────────────

# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Force specific file types
*.py        text eol=lf diff=python
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf diff=markdown
*.css       text eol=lf
*.html      text eol=lf diff=html
*.sql       text eol=lf
*.sh        text eol=lf diff=bash
*.env*      text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary

# Lock files — keep exact
package-lock.json -diff linguist-generated=true
yarn.lock         -diff linguist-generated=true
pnpm-lock.yaml    -diff linguist-generated=true

# Linguist overrides
*.md linguist-documentation
docs/** linguist-documentation
