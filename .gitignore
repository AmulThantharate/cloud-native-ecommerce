# ──────────────────────────────────────────────────────────
# 🧹 NexStore — .gitignore
# ──────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# ── Build Output ──────────────────────────────────────────
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ── Environment Variables ─────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# ── IDE ───────────────────────────────────────────────────
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# ── Docker ────────────────────────────────────────────────
*.log
docker-compose.override.yml

# ── Terraform ─────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Misc ──────────────────────────────────────────────────
*.pem
*.key
*.cert
*.secret
prompt.txt
